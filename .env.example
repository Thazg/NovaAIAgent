# ─── Backend ──────────────────────────────────────────

# Provider: "groq" (cloud-free, no GPU) or "ollama" (local)
LLM_PROVIDER=groq

# Groq (default — get free API key at https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local fallback, requires GPU/CPU)
# OLLAMA_URL=http://localhost:11434
# MODEL_NAME=qwen3:4b-instruct

LOG_LEVEL=INFO

# Backblaze B2 (persistent storage for production)
# B2_KEY_ID=00485d7e4156fd00000000001
# B2_APP_KEY=K004...
# B2_BUCKET=nova-ai-storage
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com

# ─── Frontend ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
