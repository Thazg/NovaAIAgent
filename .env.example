# ─── Backend ──────────────────────────────────────────

# Provider: "groq" (cloud-free, no GPU) or "ollama" (local)
LLM_PROVIDER=groq

# Groq (default — get free API key at https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (local fallback, requires GPU/CPU)
# OLLAMA_URL=http://localhost:11434
# MODEL_NAME=qwen3:4b-instruct

LOG_LEVEL=INFO

# ─── Frontend ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
